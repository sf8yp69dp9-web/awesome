# Copy to .env and fill in your real values
# NEVER commit .env to git!

# ── Binance Exchange ────────────────────────────────────────────────────────
EXCHANGE_API_KEY=your_binance_api_key_here
EXCHANGE_API_SECRET=your_binance_api_secret_here
EXCHANGE_NAME=binance

# ── Trading Mode ────────────────────────────────────────────────────────────
DRY_RUN=true          # true = Paper Trading (kein echtes Geld), false = Live

# ── Telegram Alerts (optional) ──────────────────────────────────────────────
# Setup:
#   1. Öffne Telegram → @BotFather → /newbot → Token kopieren
#   2. Schreibe dem Bot eine Nachricht
#   3. https://api.telegram.org/bot<TOKEN>/getUpdates → chat.id kopieren
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Claude AI Validator (optional) ──────────────────────────────────────────
# Holt sich API Key von: https://console.anthropic.com
# Kosten: ~$0.001 pro Trade-Signal
ANTHROPIC_API_KEY=
